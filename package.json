{
	"name": "south-lacrosse-www",
	"version": "1.0.0",
	"description": "SEMLA WordPress Website",
	"author": "SEMLA",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/south-lacrosse/www-dev.git"
	},
	"scripts": {
		"build:blocks": "wp-scripts build --config=webpack-full.config.js --webpack-src-dir=src/blocks --blocks-manifest --output-path=www/wp-content/plugins/semla/blocks",
		"check-engines": "wp-scripts check-engines",
		"format:blocks": "wp-scripts format ./src/blocks",
		"lint:css": "wp-scripts lint-style ./src/blocks/**/*{.css,.scss}",
		"lint:js": "wp-scripts lint-js ./src/blocks --config src/.eslintrc.json",
		"lint:scripts": "eslint ./src/scripts/*.mjs",
		"packages-update": "wp-scripts packages-update",
		"start": "cross-replace wp-scripts start --webpack-src-dir=src/blocks/$SEMLA_BLOCK --output-path=www/wp-content/plugins/semla/blocks/$SEMLA_BLOCK",
		"start-all": "wp-scripts start --config=webpack-full.config.js --webpack-src-dir=src/blocks --blocks-manifest --output-path=www/wp-content/plugins/semla/blocks",
		"build:blocks-map-dialog": "node ./src/scripts/inline-map-dialog.mjs",
		"format:non-blocks": "prettier -w . !src/blocks/**",
		"format:wp": "prettier -w www/ --ignore-path www/.prettierignore",
		"in-head-js": "uglifyjs src/js/in-head.js -c arrows=false -m -o src/js/in-head.min.js",
		"lint:plugin": "eslint www/wp-content/plugins/semla/js",
		"lint:theme": "eslint www/wp-content/themes/lax",
		"js:cal": "uglifyjs www/wp-content/plugins/semla/js/cal.js -c arrows=false -m -o www/wp-content/plugins/semla/js/cal.min.js",
		"js:colhover": "uglifyjs www/wp-content/plugins/semla/js/colhover.js -c arrows=false -m -o www/wp-content/plugins/semla/js/colhover.min.js",
		"js:inline-edit": "uglifyjs www/wp-content/plugins/semla/js/inline-edit.js -c -m -o www/wp-content/plugins/semla/js/inline-edit.min.js",
		"js:embed": "uglifyjs www/wp-content/plugins/semla/core/Rest/views/embed.js -c arrows=false -m reserved=[c,i,s,t] -o www/wp-content/plugins/semla/core/Rest/views/embed.min.js",
		"js:map": "uglifyjs www/wp-content/plugins/semla/js/map.js -c -m -o www/wp-content/plugins/semla/js/map.min.js",
		"js:main": "uglifyjs www/wp-content/themes/lax/main.js -c arrows=false -m -o www/wp-content/themes/lax/main.min.js",
		"css:plugin": "postcss \"www/wp-content/plugins/semla/css/!(*.min)*.css\" --no-map -d www/wp-content/plugins/semla/css --ext min.css -u postcss-csso autoprefixer",
		"theme-css:editor-style": "node ./src/scripts/editor-style.mjs",
		"theme-css:minify": "postcss www/wp-content/themes/lax/!(*.min)*.css --no-map -d www/wp-content/themes/lax --ext min.css -u postcss-csso autoprefixer",
		"css:theme": "run-s theme-css:editor-style theme-css:minify",
		"build:wp": "run-s js:* css:*",
		"svgo:theme": "svgo -f www/wp-content/themes/lax/img",
		"svgo:plugin": "svgo -f www/wp-content/plugins/semla/img",
		"glightbox": "node ./src/scripts/glightbox-copy.mjs",
		"js-glightbox": "node ./src/scripts/glightbox-bundle.mjs",
		"build:glightbox": "run-s glightbox js-glightbox",
		"lint": "run-s lint:*",
		"build": "run-s build:*",
		"check-links": "set NODE_TLS_REJECT_UNAUTHORIZED=0&& npx linkinator https://dev.southlacrosse.org.uk/"
	},
	"devDependencies": {
		"@wordpress/icons": "^13.1.0",
		"@wordpress/scripts": "^31.8.0",
		"autoprefixer": "^10.5.0",
		"cross-replace": "^0.2.0",
		"glightbox": "^3.3.1",
		"inline-source": "^8.0.3",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.15",
		"postcss-cli": "^11.0.1",
		"postcss-csso": "^6.0.1",
		"svgo": "^4.0.1",
		"uglify-js": "^3.19.3"
	}
}
